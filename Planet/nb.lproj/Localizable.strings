"Continue" = "Fortsett";

"Mark All as Read" = "Marker alle som lest";
"Unfollow" = "Slutt å følge";

"Do you want to save your changes as a draft?" = "Vil du arkivere endringene som et utkast?";

"Are you sure you want to unfollow this planet?" = "Er du sikker på at du vil slutte å følge dette nettstedet?";

"Here are your archived Planets. Archived planets are not auto published or updated. You can unarchive them from here." = "Her er de arkiverte nettstedene dine. Arkiverte nettsteder blir ikke automatisk publisert eller oppdatert. Du kan fjerne dem fra arkivet her.";


"Are you sure you want to delete %@? This action cannot be undone." = "Er du sikker på at du vil slette %@? Denne handlingen kan ikke angres.";

"Are you sure you want to delete this post?\n\n%@?\n\nThis action cannot be undone." = "Er du sikker på at du vil slette dette innlegget?\n\n%@?\n\nDenne handlingen kan ikke angres.";

"Would you like to use new library location at" = "Vil du bruke den nye bibliotekplasseringen på";

"current database including following planets will be replaced with contents at this location" = "gjeldende database, inkludert fulgte nettsteder, erstattes med innholdet på denne plasseringen";

"When you tip a creator, transactions will be sent to the selected Ethereum network." = "Når du tipser en skaper, sendes transaksjoner til det valgte Ethereum-nettverket.";

"Are you sure you want to archive this planet? Archived planets will not be auto updated. You can later unarchive it from settings." = "Er du sikker på at du vil arkivere dette nettstedet? Arkiverte nettsteder blir ikke automatisk oppdatert. Du kan senere fjerne det fra arkivet i innstillingene.";

"Planet lets you build and host your website on your Mac without requiring a centralized service." = "Med Planet kan du bygge og drifte nettstedet ditt på Macen uten en sentralisert tjeneste.";

"You can also use Planet to follow the content creators you like." = "Du kan også bruke Planet til å følge innholdsskapere du liker.";

"The big difference is that there is no middle layer between you and the content creators you follow." = "Den store forskjellen er at det ikke finnes noe mellomledd mellom deg og innholdsskaperne du følger.";

"You will receive the latest updates in a peer-to-peer manner." = "Du mottar de nyeste oppdateringene direkte via peer-to-peer.";

"The slug is the part of the URL that identifies the article. It should be unique and contain only lowercased letters, numbers, and hyphens." = "Sluggen er delen av URL-en som identifiserer artikkelen. Den skal være unik og bare inneholde små bokstaver, tall og bindestreker.";

"If you want this article to redirect to an external link, enter the URL here." = "Hvis du vil at denne artikkelen skal videresende til en ekstern lenke, skriver du inn URL-en her.";

"This domain will be used in places that need a domain prefix, like for RSS or Podcast feeds." = "Dette domenet brukes på steder som trenger et domeneprefiks, for eksempel RSS- eller podkaststrømmer.";

"Are you sure you want to archive this planet? Archived planets will not be auto published. You can later unarchive it from settings." = "Er du sikker på at du vil arkivere dette nettstedet? Arkiverte nettsteder publiseres ikke automatisk. Du kan senere fjerne det fra arkivet i innstillingene.";

"Please input an integer for sorting, entries with smaller numbers will be ranked first." = "Skriv inn et heltall for sortering. Oppføringer med lavere tall rangeres først.";

"Articles of the Page type are not listed on the blog index page, nor are they included in the RSS feed." = "Artikler av typen Side vises ikke på bloggindekssiden og tas heller ikke med i RSS-strømmen.";

"Are you sure you want to delete this article? This action will remove it from your feed. However, if the article is still available on the source, it will reappear in your feed the next time you refresh it." = "Er du sikker på at du vil slette denne artikkelen? Denne handlingen fjerner den fra strømmen din. Hvis artikkelen fortsatt er tilgjengelig hos kilden, vises den i strømmen igjen neste gang du oppdaterer.";


